{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.7/.schema/devbox.schema.json",
  "packages": [
    "nodejs@22"
  ],
  "shell": {
    "init_hook": [
      "(cd /tmp && corepack enable)",
      "corepack prepare pnpm@8.15.0 --activate"
    ],
    "scripts": {
      "install": "pnpm install",
      "build": "pnpm -r build",
      "test": "pnpm -r test"
    }
  }
}
