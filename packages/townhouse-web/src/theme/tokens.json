{
  "colors": {
    "canvas": "#ffffff",
    "ink": "#171717",
    "shadow": "rgba(0,0,0,0.08)",
    "type": {
      "town": "#0a72ef",
      "mill": "#de1d8d",
      "dvm": "#ff5b4f"
    }
  },
  "typescale": {
    "12": {
      "size": "0.75rem",
      "tracking": "0rem"
    },
    "14": {
      "size": "0.875rem",
      "tracking": "-0.0125rem"
    },
    "16": {
      "size": "1rem",
      "tracking": "-0.025rem"
    },
    "24": {
      "size": "1.5rem",
      "tracking": "-0.0625rem"
    },
    "32": {
      "size": "2rem",
      "tracking": "-0.1rem"
    },
    "48": {
      "size": "3rem",
      "tracking": "-0.15rem"
    }
  },
  "fontWeights": {
    "normal": "400",
    "medium": "500",
    "semibold": "600"
  },
  "fontFamilies": {
    "sans": "Geist, system-ui, sans-serif",
    "mono": "\"Geist Mono\", ui-monospace, monospace"
  },
  "animations": {
    "fade-in": {
      "keyframes": {
        "from": {
          "opacity": "0"
        },
        "to": {
          "opacity": "1"
        }
      },
      "duration": "200ms",
      "easing": "ease-out"
    },
    "pulse-soft": {
      "keyframes": {
        "0%, 100%": {
          "opacity": "1"
        },
        "50%": {
          "opacity": "0.5"
        }
      },
      "duration": "2000ms",
      "easing": "ease-in-out"
    },
    "rebal-pulse": {
      "keyframes": {
        "0%, 100%": {
          "transform": "scale(1)"
        },
        "50%": {
          "transform": "scale(1.05)"
        }
      },
      "duration": "1500ms",
      "easing": "ease-in-out"
    }
  },
  "spacing": {
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "6": "1.5rem",
    "8": "2rem",
    "12": "3rem",
    "16": "4rem"
  },
  "breakpoints": {
    "xs": "400px",
    "sm": "600px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1200px",
    "2xl": "1400px"
  },
  "shadowBorder": "0 0 0 1px rgba(0,0,0,0.08)"
}
