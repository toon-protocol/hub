{
  "name": "@toon-protocol/hub-mcp",
  "version": "0.1.0",
  "description": "MCP server letting a Claude agent (Desktop or Code) act as a full Townhouse operator: init/up, node provisioning, fee tuning, chains, credits, earnings, withdraw, plus read/telemetry.",
  "license": "MIT",
  "author": "Jonathan Green",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "hub-mcp": "./dist/mcp.js",
    "townhouse-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "peerDependencies": {
    "@toon-protocol/hub": ">=0.34.4"
  },
  "peerDependenciesMeta": {
    "@toon-protocol/hub": {
      "optional": true
    }
  },
  "devDependencies": {
    "@toon-protocol/hub": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
