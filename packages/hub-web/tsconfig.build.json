{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "*.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/components/ui/**",
    "src/charts/chart.tsx",
    "src/**/*.stories.tsx",
    "src/charts/__demo__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test-setup.ts"
  ]
}
