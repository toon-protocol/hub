{
  "name": "@toon-protocol/townhouse",
  "version": "0.1.3",
  "description": "TOON Townhouse — host-native orchestrator + dashboard for Docker-containerized TOON nodes",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "townhouse": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:canary": "vitest run --config vitest.integration.config.ts src/__integration__/connector-image-contract.test.ts"
  },
  "keywords": [
    "toon",
    "nostr",
    "ilp",
    "townhouse",
    "orchestrator",
    "docker"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toon-protocol/town.git",
    "directory": "packages/townhouse"
  },
  "author": "ALLiDoizCode",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ardrive/turbo-sdk": "^1.40.2",
    "@fastify/cors": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0",
    "@scure/bip32": "^2.0.0",
    "@scure/bip39": "^2.0.0",
    "@toon-format/toon": "^1.4.0",
    "ansi-escapes": "^7.3.0",
    "bs58": "^5.0.0",
    "dockerode": "^4.0.0",
    "fastify": "^5.0.0",
    "ink": "^5.0.0",
    "node-forge": "^1.3.3",
    "nostr-tools": "^2.23.1",
    "react": "^18.3.1",
    "viem": "^2.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@toon-protocol/client": "workspace:^",
    "@toon-protocol/core": "workspace:^",
    "@toon-protocol/mill": "workspace:^",
    "@toon-protocol/relay": "workspace:^",
    "@toon-protocol/sdk": "workspace:^",
    "@types/dockerode": "^3.3.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "ajv": "^8.0.0",
    "ajv-formats": "^3.0.0",
    "fast-check": "^3.21.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
